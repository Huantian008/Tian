{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++: g++.exe build active file",
            "type": "shell",
            "command": "E:\\MinGW\\ucrt64\\bin\\g++.exe",
            "args": [
               
    "-fdiagnostics-color=always",
    "-g",
    // 我们把 UTF-8 参数移到这里，和其他通用选项放在一起
    "-finput-charset=UTF-8",
    "-fexec-charset=UTF-8",
    // 然后，指定输入文件
    "${file}",
    // 最后，让输出选项 -o 和它的文件名参数紧挨在一起
    "-o",
    "${fileDirname}\\output\\${fileBasenameNoExtension}.exe"

            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}